---
import { fetchRepo, formatStars } from '../lib/github';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const [owner, name] = slug.split('/');
const { repo, langColor } = await fetchRepo(slug);
---

<a
  href={`https://github.com/${slug}`}
  target="_blank"
  rel="noopener noreferrer"
  class="flex flex-col gap-3 sm:gap-4 rounded-xl p-4 sm:p-5 lg:p-6 border border-white/10 bg-white/5 hover:bg-white/10 transition-colors duration-200"
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-center gap-2 min-w-0 text-white/40">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
      </svg>
      <span class="text-sm sm:text-base lg:text-lg font-medium text-white/80 truncate">{owner} / {name}</span>
    </div>
    <div class="flex items-center gap-1.5 text-white/30 text-xs sm:text-sm shrink-0 mt-0.5">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.771l-7.416 3.642 1.48-8.279L0 9.306l8.332-1.151z" />
      </svg>
      <span>{repo ? formatStars(repo.stars) : '-'}</span>
    </div>
  </div>

  <p class="text-sm lg:text-base text-white/50 leading-relaxed">
    {repo ? (repo.description || 'no description.') : 'unable to load repo info.'}
  </p>

  <div class="flex flex-wrap items-center gap-2 lg:gap-2.5">
    {repo?.language && (
      <span class="flex items-center gap-2 text-xs lg:text-sm text-white/40 mr-1">
        <span class="w-2 h-2 rounded-full shrink-0" style={`background:${langColor}`} />
        {repo.language}
      </span>
    )}
    {repo?.topics.slice(0, 4).map(topic => (
      <span class="text-xs lg:text-sm px-2.5 py-0.5 lg:px-3 lg:py-1 rounded-full font-medium text-white/50 bg-white/6 border border-white/8">
        {topic}
      </span>
    ))}
  </div>
</a>
