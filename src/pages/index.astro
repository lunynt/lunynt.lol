---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Banner from '../components/Banner.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SectionHighlight from '../components/SectionHighlight.astro';
import Currently from '../components/Currently.astro';
import ProjectCard from '../components/ProjectCard.astro';
import GuestBook from '../components/GuestBook.astro';
import { user, site } from '../config';

const cardClasses = 'relative z-10 w-full max-w-sm sm:max-w-xl lg:max-w-3xl xl:max-w-4xl rounded-2xl backdrop-blur-md bg-white/10 shadow-xl';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: user.name,
  url: site.url,
  description: site.description,
  image: site.personImage,
};
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <div class="relative flex flex-col items-center gap-4 px-4 py-10 sm:px-8 sm:py-14 lg:px-12 lg:py-16">

    <div class={`${cardClasses} overflow-hidden`}>
      <Banner src={user.banner} />

      <div class="relative z-10 px-5 sm:px-8 lg:px-10 pb-6 sm:pb-8 lg:pb-10">
        <Image src={user.pfp} alt={user.name} width={128} height={128} class="-mt-10 sm:-mt-14 lg:-mt-16 h-20 w-20 sm:h-28 sm:w-28 lg:h-32 lg:w-32 rounded-full object-cover" />
        <h1 class="mt-3 text-xl sm:text-2xl lg:text-3xl font-bold text-white">{user.name}</h1>
        <div class="group mt-1">
          <p class="text-sm sm:text-base text-white/50 cursor-default">/ {user.pronunciation} /</p>
          <div class="max-h-0 overflow-hidden group-hover:max-h-10 transition-all duration-200">
            <p class="text-xs sm:text-sm text-white/30 mt-1">"lun" like "fun", "int" like "tint/hint/mint"</p>
          </div>
        </div>
      </div>
    </div>

    <section id="currently" class={`${cardClasses} px-5 sm:px-8 lg:px-10 py-5 sm:py-7 lg:py-9`}>
      <SectionHighlight />
      <SectionHeading id="currently" label="currently" />
      <Currently />
    </section>

    <section id="about" class={`${cardClasses} px-5 sm:px-8 lg:px-10 py-5 sm:py-7 lg:py-9`}>
      <SectionHighlight />
      <SectionHeading id="about" label="about" />
      <p class="text-sm sm:text-base lg:text-lg text-white/50 leading-relaxed whitespace-pre-line">{user.about}</p>
    </section>

    <section id="projects" class={`${cardClasses} px-5 sm:px-8 lg:px-10 py-5 sm:py-7 lg:py-9`}>
      <SectionHighlight />
      <SectionHeading id="projects" label="projects" />
      <div class="flex flex-col gap-3">
        {user.projects.map(slug => <ProjectCard slug={slug} />)}
      </div>
    </section>

    <section id="guestbook" class={`${cardClasses} px-5 sm:px-8 lg:px-10 py-5 sm:py-7 lg:py-9`}>
      <SectionHighlight />
      <SectionHeading id="guestbook" label="guestbook" />
      <GuestBook />
    </section>

  </div>
</Layout>
