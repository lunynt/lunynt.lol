---
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

const inputClasses = 'w-full rounded-lg bg-white/5 border border-white/10 px-3 py-2 text-sm text-white placeholder:text-white/30 focus:outline-none focus:border-white/25 transition-colors';
---

<p class="guestbook-disabled-notice hidden text-xs text-white/40 rounded-lg bg-white/5 border border-white/10 px-3 py-2"></p>

<form id="guestbook-form" class="flex flex-col gap-3">
  <div class="flex flex-col sm:flex-row gap-3">
    <input type="text" name="name" placeholder="name (optional, anonymous by default)" maxlength="60" class={inputClasses} />
    <input type="url" name="website" placeholder="website (optional)" class={inputClasses} />
  </div>
  <textarea name="message" placeholder="leave a message..." required maxlength="500" rows="3" class={`${inputClasses} resize-none`}></textarea>

  <div class="flex flex-wrap items-center justify-between gap-3">
    <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>
    <button type="submit" class="guestbook-submit shrink-0 rounded-lg bg-white/10 hover:bg-white/15 px-4 py-2 text-sm font-medium text-white transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
      sign
    </button>
  </div>

  <p class="guestbook-error hidden text-xs text-red-400/80"></p>
  <p class="text-[10px] text-white/20 mt-1">
    By signing, you agree to an automated security check (proxy detection).
  </p>
</form>

<div id="guestbook-entries" class="flex flex-col gap-3 mt-5 pt-5 border-t border-white/10">
  <p class="text-xs text-white/40">loading entries...</p>
</div>

<div id="guestbook-vote-turnstile" class="hidden" data-sitekey={turnstileSiteKey}></div>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  import { initGuestbook } from '../scripts/guestbook';
  initGuestbook();
</script>
